# Kakunin — Environment Variables
# Copy to .env.local for local dev. Real values managed via Doppler.
# Never commit .env.local or any file with real values.

# App
NEXT_PUBLIC_APP_URL=https://www.kakunin.ai

# Supabase — Settings → API in Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AWS KMS — eu-west-1 required for GDPR compliance (MiCA Art. 70)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# ARN of root CA key — create once in KMS (RSA_2048, SIGN_VERIFY), then set here
KMS_CA_KEY_ARN=
# ARN of intermediate CA key — create once in KMS (RSA_2048, SIGN_VERIFY) for certificate delegation
KMS_INT_KEY_ARN=
# Self-signed CA certificate PEM — generated once via: npx tsx scripts/generate-ca-cert.ts
# Store output in Doppler: doppler secrets set KAKUNIN_CA_CERT_PEM="$(npx tsx scripts/generate-ca-cert.ts)"
# Served publicly at GET /v1/ca for trust chain building. Safe to expose — no secret material.
KAKUNIN_CA_CERT_PEM=
# Intermediate CA certificate PEM — generated alongside KMS_INT_KEY_ARN for certificate delegation
KAKUNIN_INT_CERT_PEM=
# S3 Object Lock WORM bucket — Compliance mode, 7-year retention
# Bucket must be created with Object Lock enabled BEFORE first write (cannot be enabled post-creation)
# aws s3api create-bucket --bucket kakunin-audit-worm-prod --region eu-west-1 --object-lock-enabled-for-bucket
AUDIT_WORM_S3_BUCKET=kakunin-audit-worm-prod

# Upstash — Redis (rate limiting) + QStash (async jobs)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
# QStash signing keys — needed to verify incoming QStash request signatures
# Get from Upstash Console → QStash → Signing Keys
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# OpenRouter — LLM routing (risk narration, anomaly detection, compliance reports)
OPENROUTER_API_KEY=

# Resend — transactional email
# Verify mail.kakunin.ai subdomain in Resend (not root domain — preserves kakunin.ai reputation)
# Add DNS: MX + SPF + DKIM + DMARC records for mail.kakunin.ai
# Inbound replies go to ai@kakunin.ai (AgentMail) — different from the sending subdomain
RESEND_API_KEY=
RESEND_FROM_EMAIL=ai@mail.kakunin.ai
RESEND_REPLY_TO=ai@kakunin.ai

# Webhooks — outbound signing key (AES-256-GCM, 32 bytes base64-encoded)
# Generate: node -e "require('crypto').randomBytes(32).toString('base64')|console.log"
WEBHOOK_SECRET_KEY=

# AgentMail — agent inbox provisioning + inbound email handling
# Inbound emails to ai@kakunin.ai route here via AgentMail webhook
# Per-agent inboxes auto-provisioned on cert issuance (username = agent slug)
AGENTMAIL_API_KEY=
# Signing secret from AgentMail webhook dashboard (Svix HMAC)
AGENTMAIL_WEBHOOK_SECRET=
# Platform inbox — receives inbound email at ai@kakunin.ai
AGENTMAIL_PLATFORM_INBOX_ID=
# Inbox provider: 'agentmail' (default) | 'resend' (fallback — alias-based, no external API)
INBOX_PROVIDER=agentmail
# Fallback inbox domain — used by ResendProvider when INBOX_PROVIDER=resend
RESEND_INBOUND_DOMAIN=mail.kakunin.ai

# Better Stack — logs, errors, uptime (replaces Sentry + PostHog)
BETTER_STACK_SOURCE_TOKEN=

# Stripe — billing (3 tiers: Starter/Professional/Enterprise)
# Webhook secret from Stripe dashboard → Webhooks → your endpoint → Signing secret
# Endpoint to register: https://kakunin.ai/api/webhooks/stripe
# Events to enable: customer.subscription.trial_will_end, invoice.payment_failed
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs from Stripe dashboard → Products → [Product] → Pricing
STRIPE_STARTER_PRICE_ID=price_1TYigBJ2IxlaARvdcmzeudS9
STRIPE_PRO_PRICE_ID=price_1TYik3J2IxlaARvdJwnY2tCm

# Supabase Auth Hook — shared secret for /api/webhooks/auth
# Set in Supabase dashboard → Authentication → Hooks → Send Email hook
# Generate: openssl rand -base64 32
SUPABASE_AUTH_HOOK_SECRET=

# Bing IndexNow API — submit new URLs to Bing for indexing
# Get from Bing Webmaster Tools → Indexing → API key
INDEXNOW_API_KEY=

# Credentials encryption — AES-256-GCM for BYOA secrets (agent API keys, webhooks, etc.)
# 32 bytes (256 bits) base64-encoded
# Generate: node -e "require('crypto').randomBytes(32).toString('base64')|console.log"
CREDENTIAL_ENCRYPTION_KEY=

# Cron jobs — webhook signature verification (internal /api/internal/cron/* routes)
# Generate: openssl rand -base64 32
CRON_SECRET=

# Discord support bot — handler webhook secret for internal verification
# Used by /api/webhooks/discord/interactions (handler side, not Vercel)
DISCORD_HANDLER_SECRET=

# Retool Admin API — internal dashboard management
# Get from Retool workspace settings → API Keys (select "Retool Token")
RETOOL_ADMIN_SECRET=

# News aggregation — for blog/news feed features
# API key for news provider (NewsAPI or similar)
NEWS_API_KEY=

# Sanity CMS — blog content management
# Get from Sanity dashboard → Settings → Project ID & Manage → Tokens
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Token should be Editor role (read+write drafts, limited settings access)
SANITY_API_TOKEN=

# Discord — customer support bot
# Get from Discord Developer Portal → Applications → Your App → Bot → Token
# Required intents: MESSAGE_CONTENT (read message content in events)
DISCORD_BOT_TOKEN=
# Support staff role ID — right-click role in Discord → Copy Role ID (enable Developer Mode first)
# Bot @mentions this role when needs_human_review is triggered (sensitive content detected)
DISCORD_SUPPORT_ROLE_ID=
# Ed25519 public key — Discord Developer Portal → Your App → General Information → Public Key
# Required for /api/integrations/discord/interactions signature verification
DISCORD_PUBLIC_KEY=
# Application ID — Discord Developer Portal → Your App → General Information → Application ID
# Required to register slash commands via scripts/register-discord-commands.ts
DISCORD_APPLICATION_ID=
# Webhook URL for #new-signups channel — created via Discord API, paste full URL
# Used by lib/discord/notify.ts to post signup embeds on new tenant creation
DISCORD_SIGNUP_WEBHOOK_URL=

# Kakunin API — service account for internal integrations (chat API, discord bot)
# Created via: POST /v1/api-keys (requires auth)
# Scoped to: chat API calls, internal message processing
KAKUNIN_API_KEY=

# Audit log signing — HMAC-SHA256 key for per-row tamper evidence (RA-125, Article 50)
# Generate: openssl rand -hex 32
# Must be 32+ bytes. Rotation requires re-signing existing rows via migration.
AUDIT_SIGNING_KEY=
KAKUNIN_WEBHOOK_SECRET=

# QStash — async job processing (already configured above in Upstash section)
# Verify QSTASH_TOKEN is set (shared with Upstash)
QSTASH_URL=https://qstash.io/v1/publish
