Design-System/
data/
CLAUDE.md

# internal planning, guidelines, and analysis docs — local only, never push
BLOG_*.md
SANITY_*.md
DELIVERABLES_*.md
README_BLOG_*.md
*-gap-analysis.md
nqzai-kakunin-wiki-*.md
# whole top-level /docs/ tree is internal (public product docs live in
# content/docs and src/app/docs). Was /docs/*.md — nested drafts
# (ai-governance-drafts, cla-staging) escaped that direct-child pattern.
/docs/
# OSS sprint working docs (strategy advisory, CLA staging, pentest report) —
# local organization only, never push. See OSS/README.md.
/OSS/
CODEBASE_REVIEW_*.md
__tests__/*.md
AGENTS.md
TODOS.md
# strategy / advisory / internal report markdown at repo root
*_Advisory.md
*_Strategy_*.md
refactoring-report.md
*-report.md
# competitive analysis, decks, and other office docs — never push
*.docx
*.pptx
*.xlsx
# one-off build/patch artifacts
*.patch
# throwaway scripts + SEO outreach work products
/scratch/
/scripts/seo/
# local pentest run output (logs contain keys + endpoints) + scratch instructions
/strix_runs/
strix-instructions*.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — block all except .env.example (which has no real values)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# fumadocs — generated at build time, not checked in
/.source
.gstack/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
.venv/
.vercel

# sub-repositories
kakunin-samples/

node_modules 2/
.agents/
.claude/
coverage/

